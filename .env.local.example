# VideoFlow Environment Variables

# Supabase Configuration (for production)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ComfyUI Integration
COMFYUI_API_URL=http://localhost:8188
COMFYUI_API_KEY=your_comfyui_key

# File Storage (for video outputs)
STORAGE_BUCKET_URL=your_s3_or_r2_url
STORAGE_ACCESS_KEY=your_storage_key
STORAGE_SECRET_KEY=your_storage_secret

# Stripe (for billing)
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# Authentication
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000